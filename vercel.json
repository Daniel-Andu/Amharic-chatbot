{
  "version": 2,
  "builds": [
    {
      "src": "customer-chat/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "installCommand": "cd customer-chat && npm ci --legacy-peer-deps",
        "buildCommand": "cd customer-chat && GENERATE_SOURCEMAP=false npm run build",
        "nodeVersion": "16.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/customer-chat/index.html"
    }
  ]
}