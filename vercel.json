{
  "version": 2,
  "builds": [
    {
      "src": "customer-chat/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "buildCommand": "cd customer-chat && npm run build:simple"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/customer-chat/index.html"
    }
  ]
}